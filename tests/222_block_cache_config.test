#!/bin/sh

#
# Test block cache size configuration:
# 1. block-cache-size-mb in fwup.conf
# 2. Default 8 MB (fallback)
#

. "$(cd "$(dirname "$0")" && pwd)/common.sh"

# Config WITH block-cache-size-mb setting
cat >$CONFIG <<EOF
block-cache-size-mb = 16

define(PART_OFFSET, 1024)
define(PART_COUNT, 1024)

file-resource rootfs {
        host-path = "${TESTFILE_1K}"
}

task complete {
    on-resource rootfs { raw_write(\${PART_OFFSET}) }
}
task upgrade {
    on-resource rootfs {
        delta-source-raw-offset=\${PART_OFFSET}
        delta-source-raw-count=\${PART_COUNT}
        raw_write(\${PART_OFFSET})
    }
}
EOF

# Config WITHOUT block-cache-size-mb setting (for default test)
cat >$CONFIG.nosize <<EOF
define(PART_OFFSET, 1024)
define(PART_COUNT, 1024)

file-resource rootfs {
        host-path = "${TESTFILE_1K}"
}

task complete {
    on-resource rootfs { raw_write(\${PART_OFFSET}) }
}
task upgrade {
    on-resource rootfs {
        delta-source-raw-offset=\${PART_OFFSET}
        delta-source-raw-count=\${PART_COUNT}
        raw_write(\${PART_OFFSET})
    }
}
EOF

# Test 1: Config file setting (16 MB)
$FWUP_CREATE -c -f $CONFIG -o $FWFILE
$FWUP_APPLY -a -d $IMGFILE -i $FWFILE -t complete

mkdir -p $WORK/data
xdelta3 -A -S -f -s $TESTFILE_1K $TESTFILE_1K $WORK/data/rootfs
cp $FWFILE $WORK/upgrade.fw
(cd $WORK && zip $WORK/upgrade.fw data/rootfs)

$FWUP_APPLY -a -d $IMGFILE -i $WORK/upgrade.fw -t upgrade -v 2>&1 | tee $WORK/output1.txt
grep -q "16 MB" $WORK/output1.txt

# Test 2: Default fallback (8 MB) when no config setting
$FWUP_CREATE -c -f $CONFIG.nosize -o $WORK/nosize.fw
rm -f $IMGFILE
$FWUP_APPLY -a -d $IMGFILE -i $WORK/nosize.fw -t complete

mkdir -p $WORK/data2
xdelta3 -A -S -f -s $TESTFILE_1K $TESTFILE_1K $WORK/data2/rootfs
cp $WORK/nosize.fw $WORK/upgrade_nosize.fw
(cd $WORK && zip $WORK/upgrade_nosize.fw data2/rootfs)

$FWUP_APPLY -a -d $IMGFILE -i $WORK/upgrade_nosize.fw -t upgrade -v 2>&1 | tee $WORK/output3.txt
grep -q "8 MB" $WORK/output3.txt
